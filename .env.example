# Copy this to .env and fill in the values you actually need.
# Most settings below have working defaults for local development —
# only the ones marked REQUIRED need a real value before that feature works.

# ── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED: choose any two long random strings (32+ chars each)
JWT_SECRET=change_me_jwt_secret_min_32_characters_long
JWT_RESET_SECRET=change_me_reset_secret_min_32_characters_long
JWT_EXPIRATION_HOURS=720

# ── Site ─────────────────────────────────────────────────────────────────────
SITE_NAME=Orbit
SITE_DESCRIPTION=A community forum
WEBSITE_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank to skip email sending (registration still works, code printed to logs)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Leave blank to disable push notifications
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
WEBPUSH_SUBSCRIBER=mailto:admin@yourdomain.com

# ── OAuth ─────────────────────────────────────────────────────────────────────
# Leave blank to disable the provider

# Google  →  https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub  →  https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database (only needed when running services outside Docker) ───────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=orbit
DB_PASSWORD=orbit
DB_NAME=orbit
DB_SSL_MODE=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=orbit-exchange
RABBITMQ_SHARDING_ENABLED=true

# ── Storage (MinIO) ───────────────────────────────────────────────────────────
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=orbit
STORAGE_USE_SSL=false
STORAGE_BASE_URL=http://localhost:9000/orbit

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
SEARCH_ENABLED=true
SEARCH_INDEX_PREFIX=orbit
SEARCH_REINDEX_ON_STARTUP=false
